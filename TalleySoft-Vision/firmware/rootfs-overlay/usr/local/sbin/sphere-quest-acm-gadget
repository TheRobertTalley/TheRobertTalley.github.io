#!/bin/sh
set -eu

udc="fcc00000.dwc3"
gadget="/sys/kernel/config/usb_gadget/sphere-quest"
config="$gadget/configs/c.1"
function_name="acm.GS0"

start_gadget() {
    modprobe libcomposite
    modprobe usb_f_acm
    if ! mountpoint -q /sys/kernel/config; then
        mount -t configfs none /sys/kernel/config
    fi

    mkdir -p "$gadget"
    echo "0x1d6b" > "$gadget/idVendor"
    echo "0x0104" > "$gadget/idProduct"
    echo "0x0100" > "$gadget/bcdDevice"
    echo "0x0200" > "$gadget/bcdUSB"
    echo "0x02" > "$gadget/bDeviceClass"
    echo "0x00" > "$gadget/bDeviceSubClass"
    echo "0x00" > "$gadget/bDeviceProtocol"

    mkdir -p "$gadget/strings/0x409"
    echo "0123456789ABCDEF" > "$gadget/strings/0x409/serialnumber"
    echo "OpenIPC" > "$gadget/strings/0x409/manufacturer"
    echo "Sphere Link FPV Bridge" > "$gadget/strings/0x409/product"

    mkdir -p "$config/strings/0x409"
    echo "250" > "$config/MaxPower"
    echo "FPV USB bridge" > "$config/strings/0x409/configuration"

    mkdir -p "$gadget/functions/$function_name"
    if [ ! -L "$config/$function_name" ]; then
        ln -s "$gadget/functions/$function_name" "$config/$function_name"
    fi
    echo "$udc" > "$gadget/UDC"

    attempt=0
    while [ ! -e /dev/ttyGS0 ]; do
        attempt=$((attempt + 1))
        if [ "$attempt" -ge 20 ]; then
            echo "ACM gadget did not create /dev/ttyGS0" >&2
            exit 1
        fi
        sleep 1
    done
}

stop_gadget() {
    if [ ! -d "$gadget" ]; then
        return
    fi
    echo "" > "$gadget/UDC" 2>/dev/null || true
}

case "${1:-start}" in
    start)
        start_gadget
        ;;
    stop)
        stop_gadget
        ;;
    *)
        echo "Usage: $0 [start|stop]" >&2
        exit 2
        ;;
esac
